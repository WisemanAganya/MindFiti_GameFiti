# ============================================================================
# PROJECT MINDSTRONG - BACKEND ENVIRONMENT CONFIGURATION
# ============================================================================
# This file connects the backend to the database, JWT, and API settings
# Copy this as .env.local in the project root (same level as package.json)
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# These must match your MySQL server setup
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here
DB_NAME=project_mindstrong

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=5000
NODE_ENV=development

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Secret key for signing JWT tokens (use a strong, random string)
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRATION=900

# ============================================================================
# FRONTEND CONFIGURATION (for CORS)
# ============================================================================
# URL where your frontend runs (dev mode)
FRONTEND_URL=http://localhost:3000

# ============================================================================
# OPTIONAL: RATE LIMITING
# ============================================================================
# RATE_LIMIT_WINDOW=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# NOTES
# ============================================================================
# 1. Database: Ensure project_mindstrong database exists with all tables
#    (Import using: mysql -u root -p < backend/project_mindstrong_PRODUCTION.sql)
#
# 2. JWT_SECRET: In production, use a cryptographically random string:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 3. DB_PASSWORD: Your MySQL root password (or limited-access user password)
#
# 4. This file should be in .gitignore for security
#
# 5. Backend will start on http://localhost:5000
#    Frontend will run on http://localhost:3000
#    CORS is configured to allow frontend requests
# ============================================================================
